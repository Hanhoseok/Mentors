# 환경 — dev / prod
ENV=dev

# DB (docker-compose 기본값)
# - driver: 운영/Linux/Mac은 asyncpg 권장. Windows + Docker Desktop은 psycopg 권장
#   (asyncpg가 ProactorEventLoop·IPv6 매핑과 마찰을 일으킴 — 자세한 건 SETUP.md 참고)
# - host: localhost는 Windows에서 IPv6(::1) 우선이라 컨테이너 도달 실패할 수 있음 → 127.0.0.1 명시
DATABASE_URL=postgresql+psycopg://mentors:mentors@127.0.0.1:5432/mentors

# Redis (cache + Pub/Sub broker)
REDIS_URL=redis://127.0.0.1:6379/0

# JWT (32+ 바이트 랜덤 권장 — 예시값 절대 그대로 쓰지 말 것)
JWT_SECRET=change-me-to-at-least-32-bytes-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google OAuth (Google Cloud Console에서 발급)
# dev에서 OAuth 거치기 싫으면 POST /auth/dev-token 사용 (ENV=dev에서만 활성)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback

# LLM provider — openai | anthropic | google
LLM_PROVIDER=google

# Embedding provider override (없으면 LLM_PROVIDER 따라감)
# ⚠️ 변경 시 기존 Chroma collection 재생성 또는 provider별 collection 분리 필요
#    (OpenAI text-embedding-3-small = 1536d, Gemini gemini-embedding-001 = 3072d).
# 자동 fallback 없음 — 지정한 provider의 API 키가 없으면 명시적 에러.
EMBEDDING_PROVIDER=openai

# chat use_case별 provider override
# 미설정 시 코드 디폴트: content → openai, debate → google
# 디폴트 provider의 API 키가 없으면 자동으로 LLM_PROVIDER로 fallback (info 로그).
# 예: dev/local에서 Gemini 키만 있을 때 CONTENT_LLM_PROVIDER=google 설정
CONTENT_LLM_PROVIDER=
DEBATE_LLM_PROVIDER=

# Naver News Search API (토론 근거 뉴스 검색)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_STREAM_TIMEOUT_S=60

# Vector store
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001

# FCM (v1.1) — 서비스 계정 JSON 파일 경로. dev에서 푸시 끄려면 빈 값 유지
FCM_CREDENTIALS_PATH=

# APScheduler (v1.1)
SCHEDULER_TIMEZONE=Asia/Seoul
# SCHEDULER_JOBSTORE_URL=  # 비워두면 DATABASE_URL 사용
