# 환경 — dev / prod
ENV=dev

# DB (docker-compose 기본값)
DATABASE_URL=postgresql+asyncpg://mentors:mentors@localhost:5432/mentors

# Redis (cache + Pub/Sub broker)
REDIS_URL=redis://localhost:6379/0

# JWT (32+ 바이트 랜덤 권장 — 예시값 절대 그대로 쓰지 말 것)
JWT_SECRET=change-me-to-at-least-32-bytes-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google OAuth (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# LLM provider — openai | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_STREAM_TIMEOUT_S=60

# Vector store
CHROMA_HOST=localhost
CHROMA_PORT=8001

# FCM (v1.1) — 서비스 계정 JSON 파일 경로. dev에서 푸시 끄려면 빈 값 유지
FCM_CREDENTIALS_PATH=

# APScheduler (v1.1)
SCHEDULER_TIMEZONE=Asia/Seoul
# SCHEDULER_JOBSTORE_URL=  # 비워두면 DATABASE_URL 사용
